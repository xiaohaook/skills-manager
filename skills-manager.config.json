{
  "scanRoots": ["~"],
  "exclude": [
    "**/node_modules/**",
    "**/.git/**",
    "**/.DS_Store",
    "**/dist/**",
    "**/build/**",
    "**/Library/**",
    "**/Applications/**",
    "**/.Trash/**",
    "**/Caches/**"
  ],
  "maxDepth": 10,
  "includeHidden": false,
  "followSymlinks": true,
  "cacheEnabled": true
}